{
  "name": "photo-salon",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "pnpm --parallel --filter @photo-salon/server --filter @photo-salon/web run start",
    "dev": "pnpm --parallel --filter @photo-salon/server --filter @photo-salon/web run dev",
    "dev:server": "pnpm --filter @photo-salon/server dev",
    "dev:web": "pnpm --filter @photo-salon/web dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "test": "pnpm run -r test",
    "test:integration": "pnpm -r test:integration",
    "compile": "pnpm run -r compile",
    "clean": "rimraf --glob 'node_modules' 'dist' 'build'",
    "db:generate": "pnpm --filter @photo-salon/database db:generate",
    "db:migrate": "pnpm --filter @photo-salon/database db:migrate",
    "migrate": "pnpm --filter @photo-salon/database migrate",
    "db:reset": "pnpm --filter @photo-salon/database reset",
    "db:seed": "pnpm --filter @photo-salon/database seed",
    "db:dev:up": "docker-compose -f docker-compose.dev.yml up -d",
    "db:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "db:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "dotenv-cli": "11.0.0",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  }
}
