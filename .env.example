# Shared
NODE_ENV=development
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/photo_salon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photo_salon

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret!!
BETTER_AUTH_URL=http://localhost:3001

# Email (disabled in dev — magic links appear in server logs)
EMAIL_ENABLED=false
EMAIL_FROM=noreply@photo-salon.local
POSTMARK_API_KEY=

# S3 / RustFS (local dev defaults)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=photo-salon-media
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin

# Polar (set POLAR_ENABLED=true for production billing)
POLAR_ENABLED=false
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_MONTHLY_PRODUCT_ID=
POLAR_YEARLY_PRODUCT_ID=
